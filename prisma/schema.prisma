generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum MessageRole {
  user
  assistant
  system
}

//////////////////////////////////////////////////////
// ORGANIZATION (MULTI-TENANT / HOSPITAL SUPPORT)
//////////////////////////////////////////////////////

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  doctors  Doctor[]
  patients Patient[]
}

//////////////////////////////////////////////////////
// CORE USER
//////////////////////////////////////////////////////

model User {
  id    String @id @db.Uuid // Matches Supabase auth.users.id
  email String @unique
  role  Role   @default(PATIENT)

  patientProfile Patient?
  doctorProfile  Doctor?

  chats            Chat[]
  memories         MedicalMemory[]
  pushSubscription PushSubscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// PROFILES
//////////////////////////////////////////////////////

model Doctor {
  id     String @id @default(uuid())
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  firstName  String
  lastName   String
  specialty  String?
  clinicName String? @default("Nala Vita Central")

  patients     Patient[]
  appointments Appointment[]
}

model Patient {
  id     String @id @default(uuid())
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  doctorId String?
  doctor   Doctor? @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  firstName   String
  lastName    String?
  dateOfBirth DateTime?
  gender      String?
  language    String    @default("English")

  heightCm   Float?
  weightKg   Float?
  bloodType  String?
  genotype   String?
  isPregnant Boolean @default(false)

  allergies  String[] // ARRAY (AI-friendly)
  conditions String[] // ARRAY (AI-friendly)

  appointments    Appointment[]
  medications     Medication[]
  labResults      LabResult[]
  dailyLogs       DailyLog[]
  medicalMemories MedicalMemory[] @relation("PatientMedicalMemories")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([organizationId])
}

//////////////////////////////////////////////////////
// CLINICAL DATA
//////////////////////////////////////////////////////

model Medication {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  name         String
  dosage       String
  frequency    String
  instructions String?

  type   String @default("PRESCRIBED")
  status String @default("ACTIVE")

  createdAt DateTime @default(now())

  @@index([patientId])
}

model Appointment {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId   String?
  doctor     Doctor? @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  doctorName String?

  date     DateTime
  time     String
  type     String   @default("Telehealth")
  location String?
  status   String   @default("Scheduled")
  notes    String?

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([doctorId])
}

model LabResult {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  title     String
  date      DateTime @default(now())
  orderedBy String?
  status    String   @default("Pending Review")

  aiSummary String?
  pdfUrl    String?

  markers LabMarker[]

  createdAt DateTime @default(now())

  @@index([patientId])
}

model LabMarker {
  id          String    @id @default(uuid())
  labResultId String
  labResult   LabResult @relation(fields: [labResultId], references: [id], onDelete: Cascade)

  name   String
  value  String
  unit   String
  range  String
  status String @default("normal")
}

//////////////////////////////////////////////////////
// DAILY TRACKING
//////////////////////////////////////////////////////

model DailyLog {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  date DateTime

  waterLiters Float   @default(0)
  steps       Int     @default(0)
  medsTaken   Boolean @default(false)

  bloodPressure String?
  heartRate     Int?
  bloodSugar    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, date])
  @@index([patientId, date])
}

//////////////////////////////////////////////////////
// AI CHAT SYSTEM
//////////////////////////////////////////////////////

model Chat {
  id     String @id @default(uuid())
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title    String
  isPinned Boolean @default(false)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Message {
  id     String @id @default(uuid())
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  role     MessageRole
  content  String
  imageUrl String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// AI MEMORY (AMELIA CORE)
//////////////////////////////////////////////////////

model MedicalMemory {
  id     String @id @default(uuid())
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  patientId String?
  patient   Patient? @relation("PatientMedicalMemories", fields: [patientId], references: [id])

  category    String
  observation String

  createdAt DateTime @default(now())

  @@index([userId, category])
  @@index([patientId])
}

//////////////////////////////////////////////////////
// PUSH NOTIFICATIONS
//////////////////////////////////////////////////////

model PushSubscription {
  id     String @id @default(uuid())
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String
  p256dh   String
  auth     String

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// AUDIT LOG (COMPLIANCE / TRACEABILITY)
//////////////////////////////////////////////////////

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  timestamp DateTime @default(now())

  @@index([userId])
}
